# ─── Teamleader OAuth2 credentials ────────────────────────────────────────────
# Register a new integration at https://marketplace.teamleader.eu/
# Set the redirect URI to: http://localhost:3000/auth/callback
TL_CLIENT_ID=your_client_id_here
TL_CLIENT_SECRET=your_client_secret_here

# ─── Pipeline IDs ──────────────────────────────────────────────────────────────
# After connecting to Teamleader, open http://localhost:3000/api/setup
# and copy the IDs for your two sales pipelines.
TL_PIPELINE_1=id-of-new-logos-pipeline
TL_PIPELINE_2=id-of-customer-growth-pipeline

# ─── Custom field IDs ─────────────────────────────────────────────────────────
# Find these at http://localhost:3000/api/setup  (look in custom_fields[])
# Leave a field blank if you don't use it.
TL_FIELD_NL=id-of-new-logo-amount-field
TL_FIELD_US=id-of-upsell-amount-field
TL_FIELD_VL=id-of-renewal-amount-field
TL_FIELD_TYPE=id-of-deal-type-field
TL_FIELD_COUNTRY=id-of-country-field
TL_FIELD_CUSTTYPE=id-of-customer-type-field

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
